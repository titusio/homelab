FROM node:24-bookworm-slim AS builder

# renovate: datasource=npm depName=obsidian-headless
ARG OBSIDIAN_HEADLESS_VERSION=0.0.11

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    make \
    g++ \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build
RUN npm install --prefix /build obsidian-headless@${OBSIDIAN_HEADLESS_VERSION}

FROM node:24-bookworm-slim

COPY --from=builder /build/node_modules /app/node_modules

RUN ln -s /app/node_modules/.bin/ob /usr/local/bin/ob

WORKDIR /vault

ENTRYPOINT ["ob"]
